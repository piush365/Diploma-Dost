// ─────────────────────────────────────────────
// 5. ROADMAPS PAGE
// ─────────────────────────────────────────────
test.describe('Roadmaps page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/#/roadmaps');
    await waitForPageLoad(page);
  });

  test('branch tabs render', async ({ page }) => {
    for (const branch of BRANCHES) {
      await expect(branchTab(page, branch)).toBeVisible();
    }
  });

  test('CS roadmap shows track selector', async ({ page }) => {
    await expect(page.getByText(/full.?stack/i).first()).toBeVisible();
  });

  test('clicking a node opens drawer', async ({ page }) => {
    await page.locator('button').filter({ hasText: /Full.?Stack|CS Core/i }).first().click();
    await page.waitForTimeout(500);
    const firstNode = page.locator('button').filter({ hasText: /days|weeks/i }).first();
    if (await firstNode.isVisible()) {
      await firstNode.click();
      await expect(page.getByText(/overview/i).first()).toBeVisible({ timeout: 8000 });
    }
  });

  test('drawer closes on backdrop click', async ({ page }) => {
    await page.locator('button').filter({ hasText: /Full.?Stack|CS Core/i }).first().click();
    await page.waitForTimeout(500);
    const firstNode = page.locator('button').filter({ hasText: /days|weeks/i }).first();
    if (await firstNode.isVisible()) {
      await firstNode.click();
      await expect(page.getByText(/overview/i).first()).toBeVisible({ timeout: 8000 });
      await page.mouse.click(10, 300);
      await page.waitForTimeout(300);
    }
  });

  test('drawer closes on Escape key', async ({ page }) => {
    await page.locator('button').filter({ hasText: /Full.?Stack|CS Core/i }).first().click();
    await page.waitForTimeout(500);
    const firstNode = page.locator('button').filter({ hasText: /days|weeks/i }).first();
    if (await firstNode.isVisible()) {
      await firstNode.click();
      await expect(page.getByText(/overview/i).first()).toBeVisible({ timeout: 8000 });
      await page.keyboard.press('Escape');
      await expect(page.getByText(/overview/i).first()).not.toBeVisible();
    }
  });

  test('IT branch loads correctly', async ({ page }) => {
    await branchTab(page, 'IT').click();
    await expect(page.getByText(/cybersecurity|cloud/i)).toBeVisible();
  });

  test('coming soon branches show placeholder', async ({ page }) => {
    await branchTab(page, 'Mech').click();
    await expect(page.getByText(/coming soon/i).first()).toBeVisible();
  });
});

