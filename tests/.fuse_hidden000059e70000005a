// @ts-check
import { test, expect } from '@playwright/test';

// ─────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────
const BRANCHES = ['CS', 'IT', 'Mech', 'Civil', 'Elec', 'ETC'];

async function waitForPageLoad(page) {
  await page.waitForLoadState('networkidle');
}

function branchTab(page, branch) {
  return page.locator('button').filter({ hasText: new RegExp('^' + branch) }).first();
}

// ─────────────────────────────────────────────
// 1. ROUTE SMOKE TESTS
// Every page must load without blank screen or JS crash
// ─────────────────────────────────────────────
test.describe('Route smoke tests', () => {
  const routes = [
    { path: '/',               name: 'Home' },
    { path: '/#/resources',    name: 'Resources' },
    { path: '/#/roadmaps',     name: 'Roadmaps' },
    { path: '/#/predictor',    name: 'Predictor' },
    { path: '/#/youtube',      name: 'YouTube Hub' },
    { path: '/#/internships',  name: 'Internships' },
    { path: '/#/community',    name: 'Community' },
    { path: '/#/msbte',        name: 'MSBTE' },
    { path: '/#/scholarships', name: 'Scholarships' },
    { path: '/#/placement',    name: 'Placement' },
    { path: '/#/opensource',   name: 'Open Source' },
    { path: '/#/dsa',          name: 'DSA' },
    { path: '/#/about',        name: 'About' },
  ];

  for (const route of routes) {
    test(`${route.name} page loads`, async ({ page }) => {
      await page.goto(route.path);
      await waitForPageLoad(page);

      // Body must not be empty
      const bodyText = await page.locator('body').innerText();
      expect(bodyText.trim().length).toBeGreaterThan(10);

      // No JS error overlay (Vite error overlay)
      const errorOverlay = page.locator('vite-error-overlay');
      await expect(errorOverlay).not.toBeAttached();

      // Page title should exist
      const title = await page.title();
      expect(title.length).toBeGreaterThan(0);
    });
  }
});

// ─────────────────────────────────────────────
// 2. NAVBAR
// ─────────────────────────────────────────────
test.describe('Navbar', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/');
    await waitForPageLoad(page);
  });

  test('navbar is visible on home page', async ({ page }) => {
    await expect(page.locator('nav')).toBeVisible();
  });

  test('logo/brand is visible', async ({ page }) => {
    // Looks for "Diploma" text anywhere in nav
    await expect(page.locator('nav').getByText(/diploma/i)).toBeVisible();
  });

  test('clicking Resources nav link navigates correctly', async ({ page, isMobile }) => {
    if (isMobile) {
      await page.locator('button[aria-label="Open menu"]').click();
      await page.waitForTimeout(300);
      await page.getByRole('link', { name: 'Resources' }).first().click();
    } else {
      await page.locator('nav').getByText(/resources/i).first().click();
    }
    await waitForPageLoad(page);
    await expect(page).toHaveURL(/#\/resources/);
  });

  test('clicking YouTube nav link navigates correctly', async ({ page, isMobile }) => {
    if (isMobile) {
      await page.locator('button[aria-label="Open menu"]').click();
      await page.waitForTimeout(300);
      await page.getByRole('link', { name: 'YouTube' }).first().click();
    } else {
      await page.locator('nav').getByText(/youtube/i).first().click();
    }
    await waitForPageLoad(page);
    await expect(page).toHaveURL(/#\/youtube/);
  });

  test('mobile hamburger menu opens and closes', async ({ page, isMobile }) => {
    test.skip(!isMobile, 'Mobile only test');
    const hamburger = page.locator('button[aria-label*="menu"], button[aria-label*="Menu"]').first();
    if (await hamburger.isVisible()) {
      await hamburger.click();
      // Menu should expand
      await expect(page.getByRole('link', { name: 'Resources' }).first()).toBeVisible();
      // Click again to close
      await hamburger.click();
    }
  });
});

// ─────────────────────────────────────────────
// 3. RESOURCES PAGE
// ─────────────────────────────────────────────
test.describe('Resources page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/#/resources');
    await waitForPageLoad(page);
  });

  test('branch tabs are visible', async ({ page }) => {
    for (const branch of ['CS', 'IT']) {
      await expect(branchTab(page, branch)).toBeVisible();
    }
  });

  test('CS tab is active by default', async ({ page }) => {
    const csTab = branchTab(page, 'CS');
    await expect(csTab).toBeVisible();
    // CS content should be shown
    await expect(page.getByText(/semester/i).first()).toBeVisible();
  });

  test('switching to IT tab loads IT resources', async ({ page }) => {
    await branchTab(page, 'IT').click();
    await waitForPageLoad(page);
    // Should still show semester content
    await expect(page.getByText(/semester/i).first()).toBeVisible();
  });

  test('switching branches does not crash', async ({ page }) => {
    for (const branch of BRANCHES) {
      await branchTab(page, branch).click();
      await page.waitForTimeout(500);
      const errorOverlay = page.locator('vite-error-overlay');
      await expect(errorOverlay).not.toBeAttached();
    }
  });

  test('resource cards have drive links', async ({ page }) => {
    // Wait for Supabase data
    await page.waitForTimeout(2000);
    const links = page.locator('a[href*="drive.google.com"]');
    const count = await links.count();
    expect(count).toBeGreaterThan(0);
  });

  test('drive links open in new tab', async ({ page }) => {
    await page.waitForTimeout(2000);
    const firstLink = page.locator('a[href*="drive.google.com"]').first();
    if (await firstLink.isVisible()) {
      await expect(firstLink).toHaveAttribute('target', '_blank');
    }
  });
});

